        <item name="cornerRadius">@dimen/card_corner_radius</item>
        <item name="android:backgroundTint">?attr/colorSecondary</item>
        <item name="android:textColor">?attr/colorOnSecondary</item>
        <item name="elevation">@dimen/card_elevation</item>
        <item name="android:layout_margin">@dimen/margin_small</item>
